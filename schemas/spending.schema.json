{
  "$id": "spending",
  "type": "object",
  "required": ["schemaVersion", "provenance", "awards"],
  "properties": {
    "schemaVersion": { "$ref": "defs#/definitions/schemaVersion" },
    "provenance": { "$ref": "defs#/definitions/provenance" },
    "awards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "fain", "recipient", "agency", "obligated", "profileUrl"],
        "properties": {
          "id": { "type": "string", "minLength": 5 },
          "fain": { "type": "string", "minLength": 3 },
          "recipient": { "type": "string", "minLength": 3 },
          "agency": { "type": "string", "minLength": 3 },
          "description": { "type": "string" },
          "obligated": { "type": "number", "minimum": 0 },
          "outlaid": { "type": ["number", "null"] },
          "outlaidAccount": { "type": ["number", "null"] },
          "periodOfPerformance": {
            "type": "object",
            "properties": {
              "start": { "type": "string" },
              "end": { "type": "string" }
            }
          },
          "profileUrl": { "type": "string", "pattern": "^https://www\\.usaspending\\.gov/" },
          "kind": { "type": "string" }
        }
      }
    },
    "chipsNotPublished": {
      "type": "object",
      "required": ["what", "finding", "checkedAt"],
      "properties": {
        "what": { "type": "string", "minLength": 20 },
        "finding": { "type": "string", "minLength": 20 },
        "cfda11037AwardsFound": { "type": "array" },
        "checkedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    }
  }
}
