{
  "$id": "defs",
  "definitions": {
    "provenance": {
      "type": "object",
      "required": ["source", "url", "retrievedAt", "vintage", "notes", "license", "attribution"],
      "properties": {
        "source": { "type": "string", "minLength": 10 },
        "url": { "type": "string", "minLength": 8 },
        "retrievedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "vintage": { "type": "string", "minLength": 4 },
        "notes": { "type": "string", "minLength": 10 },
        "license": { "type": "string", "minLength": 10 },
        "attribution": { "type": "string", "minLength": 10 }
      }
    },
    "schemaVersion": { "type": "integer", "minimum": 1, "maximum": 1 },
    "fips5": { "type": "string", "pattern": "^\\d{5}$" },
    "suppressed": {
      "type": "object",
      "required": ["suppressed"],
      "properties": { "suppressed": { "const": true } },
      "additionalProperties": false
    },
    "countCell": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "$ref": "defs#/definitions/suppressed" }
      ]
    }
  }
}
