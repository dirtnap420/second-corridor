{
  "name": "second-corridor",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "description": "The Second Corridor — tracking New York's semiconductor buildout, 2022–2045, from public data.",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-sources.mjs && node scripts/build-data-out.mjs && node scripts/build-og.mjs --cards-only && node scripts/build-pages.mjs && vite build && npm run lint:design && npm run lint:size",
    "preview": "vite preview",
    "lint:design": "node scripts/lint-design.mjs",
    "lint:size": "node scripts/lint-size.mjs",
    "geo": "node scripts/build-geo.mjs",
    "og": "node scripts/build-og.mjs",
    "data": "node scripts/refresh.mjs",
    "qa": "node qa/screenshot.mjs",
    "test": "node --test",
    "lighthouse": "node qa/lighthouse.mjs"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "d3-sankey": "^0.12.3",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "adm-zip": "^0.5.17",
    "ajv": "^8.20.0",
    "axe-core": "^4.12.1",
    "fflate": "^0.8.3",
    "lighthouse": "^13.4.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.50.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.0",
    "topojson-server": "^3.0.1",
    "topojson-simplify": "^3.0.3",
    "us-atlas": "^3.0.1",
    "vite": "^6.3.0",
    "wawoff2": "^2.0.1"
  }
}
